generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SUPERADMIN
}

enum RecordStatus {
  draft
  submitted
  archived
}

enum ReminderType {
  VAT
  CORPORATE_TAX
  GENERAL
}

enum ReminderStatus {
  pending
  done
  cancelled
}

model User {
  id                String              @id @default(cuid())
  fullName          String
  email             String              @unique
  passwordHash      String
  role              Role                @default(USER)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  businessProfile   BusinessProfile?
  vatRecords        VatRecord[]
  corporateTaxRecords CorporateTaxRecord[]
  reminders         Reminder[]
  activityLogs      ActivityLog[]
  refreshTokens     RefreshToken[]
}

model BusinessProfile {
  id            String              @id @default(cuid())
  userId        String              @unique
  businessName  String
  trn           String?
  email         String?
  phone         String?
  address       String?
  emirate       String?
  taxPeriodType String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  vatRecords    VatRecord[]
  taxRecords    CorporateTaxRecord[]
}

model VatRecord {
  id                String          @id @default(cuid())
  userId            String
  businessProfileId String?
  periodLabel       String
  periodStart       DateTime?
  periodEnd         DateTime?
  salesAmount       Float           @default(0)
  taxableSales      Float           @default(0)
  outputVat         Float           @default(0)
  purchasesAmount   Float           @default(0)
  expensesAmount    Float           @default(0)
  recoverableVat    Float           @default(0)
  zeroRatedSales    Float           @default(0)
  exemptSales       Float           @default(0)
  adjustmentVat     Float           @default(0)
  netVatPayable     Float           @default(0)
  status            RecordStatus    @default(draft)
  payload           Json
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
}

model CorporateTaxRecord {
  id                String          @id @default(cuid())
  userId            String
  businessProfileId String?
  periodLabel       String
  periodStart       DateTime?
  periodEnd         DateTime?
  incomeAmount      Float           @default(0)
  expenseAmount     Float           @default(0)
  taxableProfit     Float           @default(0)
  taxRate           Float           @default(0)
  taxAmount         Float           @default(0)
  status            RecordStatus    @default(draft)
  payload           Json
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
}

model Reminder {
  id         String         @id @default(cuid())
  userId     String
  title      String
  type       ReminderType
  dueDate    DateTime
  status     ReminderStatus @default(pending)
  emailSent  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SmtpSetting {
  id                String   @id @default(cuid())
  host              String
  port              Int
  secure            Boolean  @default(false)
  username          String
  passwordEncrypted String
  fromEmail         String
  fromName          String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  module    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
